# Build-time branding parameters consumed by scripts/apply-branding.sh
# Keep in sync with branding/custom.txt where keys overlap.

# Pinned upstream RustDesk version. Bump this to release a newer client.
UPSTREAM_VERSION=1.4.6

# Branding identity
APP_NAME="Mixel-Remote"
APP_NAME_KEBAB="mixel-remote"
APP_NAME_CAMEL="MixelRemote"
APP_DESCRIPTION="Mixel-Remote remote support client."

# OS-specific identifiers
MACOS_BUNDLE_ID="ch.mixel.remote"
WIN_PRODUCT_NAME="Mixel-Remote"
WIN_MANUFACTURER="Mixel IT and Corporate Services GmbH"
LINUX_PACKAGE_NAME="mixel-remote"

# Server config baked into the binary at build time
RENDEZVOUS_SERVER="remote.mixel.ch"
RELAY_SERVER="remote.mixel.ch"
RS_PUB_KEY="OogSlDx9l+fgs0t6ihF3uTg9emyCv01m8cr4ullarRo="

# Where to upload built artifacts
R2_BUCKET="mixel-remote-binaries"
R2_PUBLIC_HOST="download.mixel.ch"
